# ============================================================================
# Generator Control Configuration
# ============================================================================
# Copy to generator_control.env and edit.
# Plaintext passwords (USER_ lines) are auto-hashed on first startup.

# --- GPIO ---
# RELAY_PIN=27

# --- Generator Start Sequence ---
# MAX_START_RETRIES=1
# BUTTON_PRESS_DURATION=0.25
# PRIME_DELAY=0.75
# RETRY_DELAY=5

# --- Web Server ---
# HOST=0.0.0.0
# PORT=9400

# --- Rate Limiting (brute force protection) ---
# RATE_LIMIT_MAX_FAILURES=5
# RATE_LIMIT_LOCKOUT_SECONDS=300
# RATE_LIMIT_CLEANUP_SECONDS=600

# --- Logging ---
# LOG_FILE=generator_control.log
# LOG_MAX_BYTES=10485760
# LOG_BACKUP_COUNT=3
# LOG_LEVEL=INFO

# --- Users (USER_<username>=<password>) ---
# Plaintext passwords are hashed automatically on first run.
USER_chris=changeme
USER_alex=changeme
